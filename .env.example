# Server-side secrets and hosted web settings.
# Copy this file to .env locally or set these in your hosting provider dashboard.

SARVAM_API_KEY=replace_with_your_sarvam_key
TRANSCRIBER_PROVIDER=sarvam

# Heuristic is no-cost and works for demos. Use openai/gemini only after adding
# the matching API key and models below.
LLM_PROVIDER=heuristic
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

WEB_AUTH_USERNAME=team
WEB_AUTH_PASSWORD=change_this_team_password
SECRET_KEY=replace_with_a_long_random_string

DATA_DIR=/data
WEB_MAX_UPLOAD_MB=2048
WEB_WORKERS=1
WEB_THREADS=4
WEB_TIMEOUT_SECONDS=3600

# YouTube links on hosted servers may require authenticated cookies because
# YouTube can block datacenter IPs with "Sign in to confirm you're not a bot".
# Export cookies in Netscape cookies.txt format and set one of these:
# YTDLP_COOKIE_FILE=/data/youtube_cookies.txt
# YTDLP_COOKIES_TEXT=# Netscape HTTP Cookie File\n.youtube.com\tTRUE\t/\tTRUE\t...
# Local desktop only: YTDLP_COOKIES_FROM_BROWSER=chrome
# The hosted Status page can also save cookies to DATA_DIR/youtube_cookies.txt.
#
# Optional: set WEB_PIPELINE_MODE=api when MUAPI_API_KEY is configured to avoid
# server-side yt-dlp for YouTube links.
WEB_PIPELINE_MODE=local

# Set true when your app is behind HTTPS in production.
COOKIE_SECURE=false
